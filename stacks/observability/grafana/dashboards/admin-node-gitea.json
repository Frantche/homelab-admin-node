        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Admin Node / Gitea",
  "uid": "admin-node-gitea",
  "version": 1,
  "weekStart": ""
}
