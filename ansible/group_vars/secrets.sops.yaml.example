# SOPS encrypted example
admin:
  traefik_dashboard_basic_auth: "admin:$$apr1$$examplehash"
pihole:
  api_token: "replace-me"
cloudflare:
  tunnel_id: "replace-me"
  tunnel_token: "replace-me"
  account_id: "replace-me"
  dns_api_token: "replace-me"
  credentials_json: |
    {"AccountTag":"...","TunnelID":"...","TunnelSecret":"..."}
openbao:
  root_token: "replace-me"
keycloak:
  db_password: "replace-me"
  admin_user: "admin"
  admin_password: "replace-me"
  admin_recover_password: true

keycloak_config:
  enabled: true
  realm:
    name: "homelab"
    display_name: "Homelab"
  realm_roles:
    - "admin"
  clients:
    - client_id: "openbao"
      secret: "replace-me"
    - client_id: "harbor"
      secret: "replace-me"
  users:
    - username: "admin-user"
      password: "replace-me"
      realm_roles:
        - "admin"
harbor:
  admin_password: "replace-me"
openbao:
  root_token: "replace-me"
harbor_config:
  enabled: true
  oidc:
    enabled: true
    endpoint: "https://keycloak.example.com/realms/homelab"
    client_id: "harbor"
    client_secret: "replace-me"
openbao_config:
  enabled: true
  oidc:
    enabled: true
    discovery_url: "https://keycloak.example.com/realms/homelab"
    client_id: "openbao"
    client_secret: "replace-me"
backup:
  restic_default_forget_args: "--keep-daily 7 --keep-weekly 4 --keep-monthly 12 --prune"
  restic_require_secure_repositories: true
  restic_repositories:
    - name: local
      repository: "/srv/admin/backups/restic"
      password: "replace-me"
    - name: sftp
      repository: "sftp:backup-admin:/srv/restic/admin-node"
      password: "replace-me"
    - name: s3
      repository: "s3:https://s3.example.com/admin-node-restic"
      password: "replace-me"
      env:
        AWS_ACCESS_KEY_ID: "replace-me"
        AWS_SECRET_ACCESS_KEY: "replace-me"
        AWS_DEFAULT_REGION: "us-east-1"
  gitea_process:
    enabled: false
    on_calendar: "*-*-* 03:30:00"
    method: s3
    endpoint_url: "https://s3.example.com"
    bucket: "gitea-backups"
    aws_access_key_id: "replace-me"
    aws_secret_access_key: "replace-me"
    max_retention: 7
