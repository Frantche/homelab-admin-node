# Managed by Ansible.
BACKUP_ENABLE=true
BACKUP_METHODE={{ backup.gitea_process.method }}
GITEA_PROCESS_BACKUP_IMAGE={{ backup.gitea_process.image | default('ghcr.io/frantche/gitea-backup-restore-process:0.3.6') }}
GITEA_PROCESS_BACKUP_NETWORK={{ backup.gitea_process.network | default('admin-net') }}
APP_INI_PATH={{ backup.gitea_process.app_ini_path | default('/data/gitea/conf/app.ini') }}
BACKUP_PREFIX={{ backup.gitea_process.prefix | default('gitea-backup') }}
BACKUP_MAX_RETENTION={{ backup.gitea_process.max_retention | default(5) }}
BACKUP_TMP_FOLDER={{ backup.gitea_process.tmp_folder | default('/srv/admin/backups/gitea-process/tmp') }}
RESTORE_TMP_FOLDER={{ backup.gitea_process.restore_tmp_folder | default('/srv/admin/backups/gitea-process/restore-tmp') }}
{% if backup.gitea_process.method == 's3' %}
ENDPOINT_URL={{ backup.gitea_process.endpoint_url }}
AWS_ACCESS_KEY_ID={{ backup.gitea_process.aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ backup.gitea_process.aws_secret_access_key }}
BUCKET={{ backup.gitea_process.bucket }}
REGION={{ backup.gitea_process.region | default('garage') }}
S3_LOG_DEBUG={{ (backup.gitea_process.s3_log_debug | default(false) | bool) | ternary('true', 'false') }}
{% endif %}
{% if backup.gitea_process.method == 'ftp' %}
BACKUP_FTP_HOST={{ backup.gitea_process.ftp_host }}
BACKUP_FTP_USER={{ backup.gitea_process.ftp_user }}
BACKUP_FTP_PASSWORD={{ backup.gitea_process.ftp_password }}
{% if backup.gitea_process.ftp_dir is defined %}
BACKUP_FTP_DIR={{ backup.gitea_process.ftp_dir }}
{% endif %}
{% endif %}
{% for key, value in (backup.gitea_process.env | default({}) | dictsort) %}
{{ key }}={{ value }}
{% endfor %}
