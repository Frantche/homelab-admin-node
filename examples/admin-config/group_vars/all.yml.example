# Public example only — keep real secrets in group_vars/secrets.sops.yaml
ci_mode: false

service_domains:
  harbor: "harbor.example.com"
  openbao: "bao.example.com"
  keycloak: "keycloak.example.com"
  gitea: "git.example.com"
  traefik: "traefik.example.com"

hardening:
  apparmor:
    enabled: true
    enforce: true
    auto_reboot: true
    profiles:
      traefik: true
      cloudflared: true
      openbao: true

oidc_clients:
  harbor:
    client_id: "harbor"
    client_secret: "{{ vault_oidc_harbor_client_secret }}"
  openbao:
    client_id: "openbao"
    client_secret: "{{ vault_oidc_openbao_client_secret }}"
  gitea:
    client_id: "gitea"
    client_secret: "{{ vault_oidc_gitea_client_secret }}"

keycloak_config:
  enabled: true
  realm:
    name: "homelab"
    display_name: "Homelab"
  realm_roles:
    - "admin"
  clients:
    - client_id: "harbor"
      redirect_uris:
        - "https://harbor.example.com/c/oidc/callback"
      web_origins:
        - "https://harbor.example.com"
    - client_id: "openbao"
      redirect_uris:
        - "https://bao.example.com/ui/vault/auth/oidc/oidc/callback"
    - client_id: "gitea"
      redirect_uris:
        - "https://git.example.com/user/oauth2/keycloak/callback"
      web_origins:
        - "https://git.example.com"

harbor_config:
  enabled: true
  validate_certs: true
  validate_registry_mirrors: false
  oidc:
    enabled: true
    endpoint: "https://keycloak.example.com/realms/homelab"
    scope: "openid,profile,email,offline_access"
    user_claim: "preferred_username"
    groups_claim: "groups"
    admin_group: "harbor-admins"
    verify_cert: true
  registry_mirrors:
    - name: "dockerhub"
      project_name: "dockerhub"
      type: "docker-hub"
      url: "https://hub.docker.com"
      public: true
      validation:
        enabled: true
        image: "library/busybox:latest"
    - name: "quay"
      project_name: "quay"
      type: "quay"
      url: "https://quay.io"
      public: true
      validation:
        enabled: true
        image: "prometheus/busybox:latest"
    - name: "ghcr"
      project_name: "ghcr"
      type: "github-ghcr"
      url: "https://ghcr.io"
      public: true
      validation:
        enabled: true
        image: "fluxcd/flux-cli:v2.4.0"
    - name: "private-ghcr"
      project_name: "private-ghcr"
      type: "github-ghcr"
      url: "https://ghcr.io"
      public: false
      username: "{{ vault_registry_mirror_private_username }}"
      password: "{{ vault_registry_mirror_private_password }}"
      validation:
        enabled: false
        image: "OWNER/PRIVATE_IMAGE:TAG"
        username: "admin"
        password: "{{ harbor.admin_password }}"

openbao_config:
  enabled: true
  oidc:
    enabled: true
    discovery_url: "https://keycloak.example.com/realms/homelab"
    default_role: "default"
    role:
      name: "default"
      user_claim: "sub"
      groups_claim: "groups"
      allowed_redirect_uris:
        - "https://bao.example.com/ui/vault/auth/oidc/oidc/callback"
      bound_audiences:
        - "openbao"

gitea_config:
  enabled: true
  validate_certs: true
  oidc:
    enabled: true
    name: "keycloak"
    discovery_url: "https://keycloak.example.com/realms/homelab/.well-known/openid-configuration"
    scopes: "openid email profile"
  validation:
    repo: "admin-node-validation"
    issue_title: "Backup restore sentinel"
