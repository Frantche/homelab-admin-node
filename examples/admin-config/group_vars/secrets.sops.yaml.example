# SOPS encrypted example
admin:
  traefik_dashboard_basic_auth: "admin:$$apr1$$examplehash"
pihole:
  api_token: "replace-me"
cloudflare:
  tunnel_id: "replace-me"
  tunnel_token: "replace-me"
  account_id: "replace-me"
  dns_api_token: "replace-me"
  credentials_json: |
    {"AccountTag":"...","TunnelID":"...","TunnelSecret":"..."}
openbao:
  root_token: "replace-me"
keycloak:
  db_password: "replace-me"
  admin_user: "admin"
  admin_password: "replace-me"

keycloak_config:
  enabled: true
  realm:
    name: "homelab"
    display_name: "Homelab"
  realm_roles:
    - "admin"
  clients:
    - client_id: "openbao"
      secret: "replace-me"
    - client_id: "harbor"
      secret: "replace-me"
  users:
    - username: "admin-user"
      password: "replace-me"
      realm_roles:
        - "admin"
harbor:
  admin_password: "replace-me"
harbor_config:
  enabled: true
  oidc:
    enabled: true
    endpoint: "https://keycloak.example.com/realms/homelab"
    client_id: "harbor"
    client_secret: "replace-me"
openbao_config:
  enabled: true
  oidc:
    enabled: true
    discovery_url: "https://keycloak.example.com/realms/homelab"
    client_id: "openbao"
    client_secret: "replace-me"
backup:
  restic_repository: "/srv/admin/backups/restic"
  restic_password: "replace-me"
