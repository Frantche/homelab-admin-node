# Public example only — replace every placeholder before encrypting with SOPS.
vault_oidc_harbor_client_secret: "CHANGE_ME_IN_SOPS"
vault_oidc_openbao_client_secret: "CHANGE_ME_IN_SOPS"
vault_oidc_gitea_client_secret: "CHANGE_ME_IN_SOPS"

admin:
  traefik_dashboard_basic_auth: "admin:$$apr1$$examplehash"

pihole:
  api_token: "CHANGE_ME_IN_SOPS"

cloudflare:
  tunnel_id: "CHANGE_ME_IN_SOPS"
  tunnel_token: "CHANGE_ME_IN_SOPS"
  account_id: "CHANGE_ME_IN_SOPS"
  dns_api_token: "CHANGE_ME_IN_SOPS"
  credentials_json: |
    {"AccountTag":"...","TunnelID":"...","TunnelSecret":"..."}

keycloak:
  db_password: "CHANGE_ME_IN_SOPS"
  admin_user: "admin"
  admin_password: "CHANGE_ME_IN_SOPS"

keycloak_config:
  groups:
    - "harbor-admins"
  users:
    - username: "admin-user"
      password: "CHANGE_ME_IN_SOPS"
      email: "admin@example.com"
      first_name: "Admin"
      last_name: "User"
      email_verified: true
      temporary_password: false
      groups:
        - "harbor-admins"

harbor:
  admin_password: "CHANGE_ME_IN_SOPS"
  db_password: "CHANGE_ME_IN_SOPS"
  core_secret: "CHANGE_ME_IN_SOPS"
  jobservice_secret: "CHANGE_ME_IN_SOPS"
  registry_password: "CHANGE_ME_IN_SOPS"

gitea:
  admin_user: "admin"
  admin_password: "CHANGE_ME_IN_SOPS"
  db_password: "CHANGE_ME_IN_SOPS"
  secret_key: "CHANGE_ME_IN_SOPS"
  internal_token: "CHANGE_ME_IN_SOPS"
  jwt_secret: "CHANGE_ME_IN_SOPS"

openbao:
  root_token: "CHANGE_ME_IN_SOPS"

backup:
  restic_default_forget_args: "--keep-daily 7 --keep-weekly 4 --keep-monthly 12 --prune"
  restic_require_secure_repositories: true
  restic_repositories:
    - name: local
      repository: "/srv/admin/backups/restic"
      password: "CHANGE_ME_IN_SOPS"
    - name: sftp
      repository: "sftp:backup-admin:/srv/restic/admin-node"
      password: "CHANGE_ME_IN_SOPS"
    - name: s3
      repository: "s3:https://s3.example.com/admin-node-restic"
      password: "CHANGE_ME_IN_SOPS"
      env:
        AWS_ACCESS_KEY_ID: "CHANGE_ME_IN_SOPS"
        AWS_SECRET_ACCESS_KEY: "CHANGE_ME_IN_SOPS"
        AWS_DEFAULT_REGION: "us-east-1"
