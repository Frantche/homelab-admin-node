[Unit]
Description=Gitea backup via gitea-backup-restore-process
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/srv/admin/env/gitea-process-backup.env
ExecStart=/usr/bin/flock -n /run/admin-node-operation.lock /opt/homelab-admin-node/scripts/gitea-process-backup.sh
