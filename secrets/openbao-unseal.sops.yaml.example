openbao:
  active_keyset: "2026-05-initial"
  keysets:
    "2026-05-initial":
      threshold: 3
      unseal_keys:
        - "..."
        - "..."
        - "..."
        - "..."
        - "..."
  backup_token: "..."

openbao_config:
  enabled: true
  root_token: "replace-me"
  secret_engines:
    - path: "secret"
      type: "kv-v2"
  oidc:
    enabled: true
    discovery_url: "https://keycloak.example.com/realms/homelab"
    client_id: "openbao"
    client_secret: "replace-me"
    default_role: "default"
    role:
      name: "default"
      user_claim: "preferred_username"
      groups_claim: "groups"
      allowed_redirect_uris:
        - "https://bao.example.com/ui/vault/auth/oidc/oidc/callback"
      bound_audiences:
        - "openbao"
      policies:
        - "default"
    roles:
      - name: "admin"
        group: "admin"
        secret_engines:
          - "secret"
